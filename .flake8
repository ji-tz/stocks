[flake8]
max-line-length = 120
extend-ignore = E203, W503, F401, F841, E402
exclude = .git,__pycache__,build,dist,.venv,venv,screenshots,data,tests/guitests
per-file-ignores =
    __init__.py: F401
    test_*.py: E302,E305,W291
    probe_stocks.py: E501
    exchange/source/akshare_provider.py: E501
    test_ak.py: E501
    tools/clean_data_cache.py: F541
    trader/simulator.py: E501,F824
