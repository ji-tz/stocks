[MASTER]
ignore=.git,__pycache__,build,dist,.venv,venv,screenshots
extension-pkg-allow-list=

[MESSAGES CONTROL]
# Disable: missing-docstring, missing-class-docstring, missing-function-docstring,
# too-few-public-methods, unused-argument, broad-except, too-many-arguments,
# similar-lines, too-many-instance-attributes, too-many-locals
disable=C0114,C0115,C0116,R0903,W0612,W0613,W0703,R0913,R0801,R0902,R0914

[FORMAT]
max-line-length=120

[REPORTS]
output-format=colorized
score=no
